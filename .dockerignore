# Local build artifacts — repopulated inside the image.
bin/
build/
target/
coverage/
*.test
*.out

# Workspace + runtime DBs are per-host state, not source.
.neo/db/
.neo/pki/
.neo/snapshots/
.neo/logs/
.neo/models/
.neo/.env
.neo/credentials.json
.neo/daemon.pid
.neo/neo-mcp.pid
.neo/mode

# Frontend build cache; the Dockerfile runs `npm ci` from scratch.
web/node_modules/
web/dist/
web/.vite/

# IDE / OS noise.
.idea/
.vscode/
.DS_Store

# Git is not needed inside the image (and bloats context).
.git/
.github/

# Docs + scratch — not consumed at runtime.
docs/
README.md
CHANGELOG.md
*.md
!cmd/**/README.md

# Pre-staged HUD bundle is regenerated by the Stage-2 hud-builder.
# Keep this last so the previous wildcards don't accidentally re-include it.
cmd/neo-nexus/static/

# Test fixtures + plugin echo (test-only).
cmd/plugin-echo/
