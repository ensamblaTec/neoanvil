# NeoAnvil docker-compose env overrides (Area 1.1.B)
#
# Copy to `.env` and edit. docker-compose reads `.env` automatically.
# `.env` is gitignored — `.env.example` is the committed template.

# ─── Image tags ────────────────────────────────────────────────────────
NEOANVIL_TAG=local
OLLAMA_TAG=latest

# ─── CPU baseline (build-time) ─────────────────────────────────────────
# v3 = Haswell+/Zen1+ (default, AVX2/FMA/BMI2).
# v1 = portable lowest-common-denominator.
# v4 = Skylake-X+/Zen4+ (AVX-512). Verify host CPU first.
GOAMD64=v3

# ─── Port overrides ────────────────────────────────────────────────────
# Defaults match the canonical native-install ports. If you have a
# native NeoAnvil running on this machine and want side-by-side, shift
# all four to a free range:
#
#   NEXUS_PORT=19000
#   HUD_PORT=18087
#   OLLAMA_PORT=11534
#   OLLAMA_EMBED_PORT=11535
#
NEXUS_PORT=9000
HUD_PORT=8087
OLLAMA_PORT=11434
OLLAMA_EMBED_PORT=11435

# ─── Pattern D — host bind paths (Area 1.4) ────────────────────────────
# REPO_PATH bind-mounts the source directory at /home/neo/work/repo so
# neoanvil reads/writes the same files your IDE edits. Defaults to the
# directory `docker compose` was invoked from. Override to mount a
# different repo, or set to empty if you don't want any host bind:
#
#   REPO_PATH=/home/me/projects/some-other-repo
#
REPO_PATH=
# (left empty to use ${PWD} default)
