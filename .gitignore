repomix-output.*
bin/
.DS_Store

# ===================================================================
# .neo/ — reglas granulares (NO ignorar todo con .neo/)
# ===================================================================
# Estado runtime — específico de máquina, NUNCA commitear
.neo/db/
.neo/pki/
.neo/snapshots/
.neo/logs/
.neo/daemon.pid
.neo/neo-mcp.pid
.neo/brain_test.db
.neo/models/
.neo/.env
.neo/mode
# [ADR-016] Ouroboros lifecycle hooks state
.neo/blast_cache.json
.neo/session_pending_cert.list
# docker-compose runtime overrides (1.1.B). .env.example is the committed template.
.env
.neo/credentials.json
.neo/docs/doc-prev-note
.claude/scheduled_tasks.lock

# Federation migration bundles — snapshot .zip pueden superar 50MB;
# generados on-demand con scripts de bundle. README-neo-bundle.md sí
# se versiona como puntero al contenido.
.neo/docs/neo-bundle-*.zip
.neo/docs/*.zip

# .neo/ espúreos en subdirectorios de paquetes — artefacto del bug de certify
# donde t.workspace resolvía al directorio del paquete en lugar del repo root.
# Corregido por projectRootOf() (Épica 96) pero se guarda como defensa en profundidad.
cmd/**/.neo/
pkg/**/.neo/

# .neo-project/ en el raíz del repo — artefacto del bug pre-Épica 266 donde
# findNeoProjectDir aceptaba cualquier directorio .neo-project/ sin neo.yaml.
# Corregido en Épica 266. Este directorio solo debe existir en el PADRE del repo.
.neo-project/

# Archivos que SÍ van al repo (plan, deuda técnica, postmortems)
# .neo/master_plan.md       ← commiteado
# .neo/technical_debt.md    ← commiteado
# .neo/incidents/           ← commiteado

# ===================================================================
# Binarios y artefactos
# ===================================================================

# Binaries outside bin/
/neo-mcp
/neo
/neo-nexus
/hud
/stress
/cmd/neo-tui/neo-tui
/cmd/neo-mcp/neo-mcp

# PKI raw files (fuera de .neo/ también)
*.crt
*.key
*.csr
*.srl
pki/

# Logs y outputs
*.log
**.err
**.out

# Herramientas temporales
stress_tool
in/
in/sandbox

# Frontend
web/node_modules/
web/dist/
web/package-lock.json

# [PILAR-XXVII/245.Q] SPA bundle staged into cmd/neo-nexus/static/ by
# `make build-hud`. Re-generated by `make build-nexus` on every build,
# so keeping it out of git avoids ~1.5 MB of binary churn per frontend
# change. index.html is kept (reference) — only the hashed bundle is ignored.
cmd/neo-nexus/static/assets/
cmd/neo-nexus/static/favicon.svg
cmd/neo-nexus/static/icons.svg

# BoltDB sueltos en la raíz
brain.db
# .mcp.json contains the workspace ID, which is determinístico-per-path
# (Épica 106) but path differs per machine. Each machine maintains its own.
.mcp.json

# PGO profile — binary blob captured per-machine from real workload.
# Regenerated via `make capture-profile`. Never commit. [Épica 364.A]
default.pgo
*.pgo
/plugin-deepseek

# Compiled binaries (NEVER commit)
cmd/neo/neo

# Session logs (private, not for public repo)
docs/session/report*.md
docs/session/SESSION-*.md
/plugin-jira
/plugin-github
cmd/plugin-jira/plugin-jira
cmd/plugin-github/plugin-github
.neo/b1-measurements.csv
