# NeoAnvil workspace secrets — copia este fichero a .neo/.env y rellena los valores.
# .neo/.env está en .gitignore — nunca lo commitees.
# Las variables del shell tienen prioridad sobre este fichero.

# ============================================================================
# PostgreSQL — DB_SCHEMA y neo_radar DB intent
# Formato: postgres://user:password@host:port/dbname?sslmode=disable
# ============================================================================
SERVER_PROD_DSN=postgres://user:password@host:5432/dbname?sslmode=disable

# ============================================================================
# PILAR XXIII — Subprocess MCP plugins (Jira, GitHub, etc.)
# ============================================================================
# Dos caminos para credenciales de plugins:
#
#  RECOMENDADO — `neo login` + keystore + vault injection:
#      neo login --provider jira --token <X> --email <Y> --domain <Z>
#    Ventajas: audit log inmutable, OS-keychain encryption opcional,
#    expiry tracking, rotation via Provider interface.
#    Almacena en: ~/.neo/credentials.json (0600) o Keychain/libsecret.
#
#  ALTERNATIVA dev — env vars directos (este archivo):
#    El plugin spawneado los lee via os.Getenv. Sin audit, sin rotation,
#    sin encryption — apto para iteración local rápida.
#
# Si optas por la alternativa env, descomenta y rellena:
#
# JIRA_TOKEN=atlassian_api_token_aqui
# JIRA_EMAIL=tu_correo@empresa.com
# JIRA_DOMAIN=empresa.atlassian.net
# JIRA_TENANT_ID=opcional_para_multi_tenant
#
# GITHUB_TOKEN=ghp_xxx
# GITHUB_EMAIL=tu_correo@empresa.com
#
# ---- Active space / board (PILAR XXIII / 124.8) ----
# El plugin sabe "dónde estoy trabajando" via estos env vars, inyectados
# automáticamente desde ~/.neo/contexts.json al spawn del subprocess.
# Configurar con:
#   neo space use --provider jira --id ENG --name "Engineering" \
#                 --board 15 --board-name "Sprint Board"
#
# Si prefieres setearlos directamente aquí (bypass al ContextStore):
# JIRA_ACTIVE_SPACE=ENG
# JIRA_ACTIVE_SPACE_NAME=Engineering
# JIRA_ACTIVE_BOARD=15
# JIRA_ACTIVE_BOARD_NAME=Sprint Board

# Adaptive runtime experiment (feature/adaptive-runtime branch)
# Disable the SessionStart Tool Discipline Mirror — set =1 for the baseline
# arm of the A/B test, leave unset/=0 for treatment arm. See
# docs/general/b1-measurement-protocol.md.
# NEO_BRIEFING_DIFF_DISABLE=1
